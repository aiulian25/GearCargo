# ============================================================
# GearCargo - Production Environment Configuration
# ============================================================
# IMPORTANT: Copy this file to .env and fill in all values
# NEVER commit .env to version control!
# ============================================================

# ================== GENERAL SETTINGS ==================
APP_URL=https://your-domain.com
APP_PORT=5000
DEFAULT_THEME=dark

# User/Group IDs (match your host system user)
PUID=1000
PGID=1000

# ================== SECURITY - SECRETS ==================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_64_CHAR_HEX
JWT_SECRET_KEY=CHANGE_ME_GENERATE_64_CHAR_HEX
WTF_CSRF_SECRET_KEY=CHANGE_ME_GENERATE_64_CHAR_HEX
ENCRYPTION_KEY=CHANGE_ME_GENERATE_64_CHAR_HEX

# ================== DATABASE ==================
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ================== REDIS ==================
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ================== JWT TOKENS ==================
# Access token expiry in seconds (default: 1 hour)
JWT_ACCESS_TOKEN_EXPIRES=3600
# Refresh token expiry in seconds (default: 30 days)
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ================== CORS & RATE LIMITING ==================
# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-domain.com
RATELIMIT_DEFAULT=100 per hour

# ================== EMAIL (Required for password reset) ==================
MAIL_ENABLED=true
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
# For Gmail, use App Password: https://support.google.com/accounts/answer/185833
MAIL_PASSWORD=CHANGE_ME_APP_PASSWORD
MAIL_DEFAULT_SENDER=GearCargo <your-email@gmail.com>

# ================== PUSH NOTIFICATIONS (VAPID) ==================
# Generate VAPID keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:your-email@gmail.com

# ================== OLLAMA AI (Optional) ==================
OLLAMA_ENABLED=false
# If running Ollama on host machine:
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=30

# ================== ADMIN ACCOUNT ==================
# Only used during initial setup, remove after first boot
# ADMIN_USERNAME=admin
# ADMIN_EMAIL=admin@your-domain.com
# ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
