{
  "name": "GearCargo",
  "short_name": "GearCargo",
  "description": "Vehicle management and expense tracking PWA",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0f172a",
  "theme_color": "#2563eb",
  "orientation": "portrait-primary",
  "scope": "/",
  "id": "/",
  "lang": "en",
  "dir": "ltr",
  "icons": [
    {
      "src": "/logo.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/logo.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "categories": ["productivity", "utilities", "lifestyle"],
  "shortcuts": [
    {
      "name": "Add Fuel",
      "short_name": "Fuel",
      "description": "Add a fuel entry",
      "url": "/fuel/add",
      "icons": [{"src": "/logo.png", "sizes": "96x96"}]
    },
    {
      "name": "Add Service",
      "short_name": "Service",
      "description": "Add a service entry",
      "url": "/services/add",
      "icons": [{"src": "/logo.png", "sizes": "96x96"}]
    },
    {
      "name": "My Vehicles",
      "short_name": "Vehicles",
      "description": "View your vehicles",
      "url": "/vehicles",
      "icons": [{"src": "/logo.png", "sizes": "96x96"}]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": ["image/*", "application/pdf"]
        }
      ]
    }
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "handle_links": "preferred",
  "screenshots": [],
  "prefer_related_applications": false,
  "related_applications": []
}
