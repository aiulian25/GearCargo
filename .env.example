# ============================================================
# GearCargo — configuration (.env)
# ============================================================
# The easiest way to fill this in is to run ./setup.sh — it generates every
# secret below for you and only asks for your URL. To do it by hand, set the
# REQUIRED block; everything else has safe defaults.
#
# Full list of every available option:  examples/.env.reference
#
# ⚠️  MIGRATING an existing install? Reuse your EXISTING ENCRYPTION_KEY (and the
#     other secrets). A different ENCRYPTION_KEY makes encrypted data unreadable.

# ─── REQUIRED ───────────────────────────────────────────────
# The URL you'll access GearCargo at (used for links, CORS, cookies).
APP_URL=http://localhost:5000

# Secrets — generate strong values. setup.sh does this automatically. By hand:
#   token:   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#   Fernet:  python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=
JWT_SECRET_KEY=
WTF_CSRF_SECRET_KEY=
ENCRYPTION_KEY=              # MUST be a Fernet key (see above) — not plain hex
DB_PASSWORD=
REDIS_PASSWORD=

# ─── COMMON (optional) ──────────────────────────────────────
APP_PORT=5000               # Synology: 5050 (DSM uses 5000/5001)
CORS_ORIGINS=http://localhost:5000   # normally the same as APP_URL
TRUSTED_PROXY_COUNT=1       # reverse proxies in front of the app (0 = direct)
DEFAULT_THEME=dark
# If a reverse proxy runs on THIS host, set APP_BIND_IP=127.0.0.1 so the app is
# not reachable in plaintext from the network. Leave unset to listen on all NICs.
# APP_BIND_IP=127.0.0.1

# ─── EMAIL — optional (password reset / notifications) ──────
MAIL_ENABLED=false
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=GearCargo <no-reply@example.com>

# ─── PUSH NOTIFICATIONS — optional ──────────────────────────
# VAPID_PRIVATE_KEY is a Docker secret (./secrets/vapid_private_key). setup.sh
# generates both. The public key + subject are non-sensitive:
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ─── ADVANCED (optional) ────────────────────────────────────
# External DB/Redis, Ollama AI, GeoIP, upload limits, server tuning, etc.
# See examples/.env.reference for the full documented list.
