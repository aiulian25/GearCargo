# GearCargo Environment Configuration
# Copy this file to .env and configure your settings

# ============================================================
# APPLICATION SETTINGS
# ============================================================
APP_NAME=GearCargo
APP_URL=http://localhost:5000
APP_PORT=5000
# FLASK_ENV gates production security checks. Keep this as "production" for any
# real deployment: the app then REFUSES TO START if the secrets below are still
# placeholders (this is independent of DEBUG). Set FLASK_ENV=development ONLY for
# local development to bypass the check and run with the placeholder secrets.
FLASK_ENV=production
DEBUG=false

# ============================================================
# SECRETS (CHANGE ALL THESE IN PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================
SECRET_KEY=change-this-to-a-secure-64-character-secret-key-in-production
JWT_SECRET_KEY=change-this-jwt-secret-key-must-be-different-from-secret-key
WTF_CSRF_SECRET_KEY=change-this-csrf-secret-key-for-form-protection
ENCRYPTION_KEY=change-this-32-byte-hex-encryption-key-for-sensitive-data
# Encryption key ROTATION (S06): when changing ENCRYPTION_KEY, put the OLD key(s)
# here (comma-separated) so existing data keeps decrypting during migration.
# Then run: docker compose exec gearcargo python scripts/reencrypt_pii.py --execute
# and remove this line once it reports 0 undecryptable rows.
# ENCRYPTION_KEYS_OLD=

# ============================================================
# DATABASE
# ============================================================
DB_PASSWORD=change-this-secure-database-password

# Opt-in schema self-heal (recovery only). When 'true', the entrypoint runs a
# model-introspection pass (create_all + ADD COLUMN IF NOT EXISTS) after
# migrations to fix a DRIFTED schema. Leave unset/false on normal boots —
# Alembic migrations (flask db upgrade) own the schema, and running this every
# boot lengthens startup. Set DB_SCHEMA_SYNC=true only for one-off recovery.
# DB_SCHEMA_SYNC=false

# ============================================================
# REDIS (Cache, Sessions, Rate Limiting)
# ============================================================
REDIS_PASSWORD=change-this-redis-password

# ============================================================
# SECURITY - CORS (Cross-Origin Resource Sharing)
# Comma-separated list of allowed origins
# ============================================================
CORS_ORIGINS=http://localhost:5000,https://yourdomain.com
CORS_SUPPORTS_CREDENTIALS=true

# ============================================================
# SECURITY - CSRF Protection
# ============================================================
WTF_CSRF_ENABLED=true

# ============================================================
# SECURITY - Rate Limiting
# ============================================================
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=200 per day

# ============================================================
# SECURITY - Session/Cookie Settings
# Set SESSION_COOKIE_SECURE=true only when using HTTPS
# ============================================================
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ============================================================
# SECURITY - Domain-Based Access Control
# Separate admin and user domains for security segregation.
# If set, admins can only login on ADMIN_DOMAIN, users on USER_DOMAIN.
# Leave empty to allow all users on all domains.
# ============================================================
ADMIN_DOMAIN=
USER_DOMAIN=

# ============================================================
# SECURITY - JWT Token Expiry (in seconds)
# ============================================================
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ============================================================
# DOCKER USER IDS (Linux only - match your host user)
# Find with: id -u && id -g
# ============================================================
PUID=1000
PGID=1000

# ============================================================
# THEME SETTINGS
# ============================================================
DEFAULT_THEME=dark
# Dark theme accent: #2563eb (blue)
# Light theme accent: #6b7280 (grey)

# ============================================================
# EMAIL (SMTP) CONFIGURATION
# ============================================================
MAIL_ENABLED=false
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@gearcargo.local

# ============================================================
# PUSH NOTIFICATIONS (VAPID KEYS)
# Generate with: npx web-push generate-vapid-keys
# ============================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@gearcargo.local

# ============================================================
# OLLAMA CONFIGURATION (External Instance)
# Point to your existing Ollama server (run: ollama list  to see models)
# ============================================================
OLLAMA_ENABLED=true

# URL of your Ollama server — use your server's LAN IP or hostname
# If Ollama runs on the same Docker host: use host.docker.internal
OLLAMA_BASE_URL=http://host.docker.internal:11434
# External Ollama on LAN: OLLAMA_BASE_URL=http://YOUR_OLLAMA_IP:11434

# Increase timeout for larger models on slower hardware (seconds)
OLLAMA_TIMEOUT=60

# ------------------------------------------------------------------
# Model selection guide for GearCargo's tasks:
#
#  qwen2.5   — Best overall: structured JSON, multilingual (EN/RO/ES)
#               Recommended for predictions, reminders, and OCR.
#
#  llama3.2  — Fastest/lightest: good for simple classification tasks
#               (anomaly detection). Lower VRAM, sub-second responses.
#
#  gemma4    — Strong reasoning; use if you prefer Google's stack.
#               qwen2.5 edges it on multilingual output.
#
# Optimal split (per-task overrides take priority over OLLAMA_MODEL):
# ------------------------------------------------------------------

# Global fallback — used for any task that has no per-task override
OLLAMA_MODEL=qwen2.5

# Maintenance predictions  (complex JSON + EN/RO/ES translations)
OLLAMA_MODEL_PREDICT=qwen2.5

# Receipt OCR  (structured extraction: date, amount, vendor, line items)
OLLAMA_MODEL_OCR=qwen2.5

# Max concurrent OCR scans (pytesseract is CPU-bound). Lower to 1 on small hosts
# to keep CPU available for request handling; raise on bigger boxes. Default: 2.
OCR_MAX_CONCURRENCY=2

# Fuel anomaly detection  (simple classification — speed matters)
OLLAMA_MODEL_ANOMALY=llama3.2

# Reminder drafting  (3 suggestions with EN/RO/ES titles + notes)
OLLAMA_MODEL_REMINDER=qwen2.5

# ------------------------------------------------------------------
# Vehicle chat hardening (CHAT_HARDENING_PLAN §14) — optional tuning.
# All have safe defaults (shown); uncomment to override.
#
# DISTRIBUTED / REMOTE Ollama: point OLLAMA_BASE_URL at the remote host's
# LAN IP / DNS, and use https + a private network (VPN/VLAN) — the default
# host.docker.internal only resolves the backend's OWN host. Never expose
# port 11434 to the public internet unauthenticated.
#
# Timeout invariant (keep under GUNICORN_TIMEOUT=360 with margin):
#   OLLAMA_CONNECT_TIMEOUT + CHAT_CLASSIFIER_TIMEOUT
#   + OLLAMA_CONNECT_TIMEOUT + CHAT_MAIN_TIMEOUT  <  GUNICORN_TIMEOUT
#   (defaults: 5 + 15 + 5 + 90 = 115 < 360)
# ------------------------------------------------------------------
# Short connect timeout so a dead/unrouteable remote fails in seconds.
#OLLAMA_CONNECT_TIMEOUT=5
# Per-hop read budgets for chat (dedicated, not the global OLLAMA_TIMEOUT).
#CHAT_CLASSIFIER_TIMEOUT=15
#CHAT_MAIN_TIMEOUT=90
# Layer 2 input classifier (small/fast model gates off-topic chat).
# Falls back to the global model if OLLAMA_MODEL_CLASSIFIER is blank.
#OLLAMA_MODEL_CLASSIFIER=llama3.2:1b
#CHAT_CLASSIFIER_ENABLED=true
#CHAT_CLASSIFIER_FAIL_OPEN=true       # on classifier error → fall through to main (L1+L3 still guard)
#CHAT_CLASSIFIER_NUM_PREDICT=16       # tiny output cap (it only emits ALLOW/BLOCK)
# Optional Layer 3 phase-2: second classifier pass over the ANSWER (adds a call).
#CHAT_OUTPUT_CLASSIFIER_ENABLED=false
# Main model temperature (0.3–0.5). CHAT_TEMPERATURE is also accepted.
#CHAT_MAIN_TEMPERATURE=0.3
# Assistant persona name (defaults to APP_NAME; white-label safe).
#CHAT_ASSISTANT_NAME=GearCargo
# Per-user chat rate limit (Flask-Limiter syntax; ';'-separated). Default is
# generous for a normal conversation; the per-minute cap bounds abuse.
#CHAT_RATE_LIMIT=15 per minute; 100 per hour

# ============================================================
# DOCKER USER IDS (Linux only - match your user)
# ============================================================
PUID=1000
PGID=1000

# ============================================================
# AUTOMATED BACKUPS
# Number of daily/weekly archives to keep before rotating.
# Archives are written to ./volumes/backups/system/{daily,weekly}/
# and are compatible with restore.sh.
# Run a manual backup: docker compose exec backup sh /usr/local/bin/backup.sh manual
# ============================================================
BACKUP_KEEP_LAST=7

# ============================================================
# REVERSE PROXY & IP DETECTION
# Number of trusted reverse proxies in front of the app.
#   0 — direct-bind (no proxy);
#   1 — one proxy (nginx/Traefik/Cloudflare)  ← production default
#   2 — CDN + proxy (e.g. Cloudflare + nginx)
# ============================================================
TRUSTED_PROXY_COUNT=1

# ============================================================
# GEOIP (optional — for suspicious-login country detection)
# Download free GeoLite2-City.mmdb from MaxMind:
#   https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
# Place in ./volumes/geoip/ and set the container path below.
# Leave empty to disable (login still works normally).
# ============================================================
GEOIP_DB_PATH=
# Example: GEOIP_DB_PATH=/app/volumes/geoip/GeoLite2-City.mmdb

# ============================================================
# WIDGET API (Gethomepage integration)
# CORS origin allowlist for the /api/widget/ endpoints (API-key auth, no cookies).
# RECOMMENDED: set an explicit allowlist of the origin(s) that embed the widget in
# a browser. Comma- or space-separated; the server echoes back a matching Origin.
# Server-side callers (Gethomepage) send no Origin and work regardless of this.
# Leaving it as '*' is permitted but logs a startup warning (any site can read it
# cross-origin from a browser).
# ============================================================
WIDGET_CORS_ORIGINS=https://homepage.yourdomain.com
# Permissive fallback (logs a warning): WIDGET_CORS_ORIGINS=*

# ============================================================
# PERFORMANCE
# Gunicorn worker count — capped to avoid OOM on many-core hosts.
# Rule of thumb: (cpu_cores * 2) + 1, but keep ≤ 4 inside Docker.
# ============================================================
GUNICORN_WORKERS=4
