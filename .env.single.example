# ============================================================
# GearCargo — Single-Image (.env) example
# ============================================================
# Copy to `.env` next to docker-compose.single.yml and fill in.
#
# ⚠️  MIGRATING from the 4-container stack?  REUSE your existing
#     ENCRYPTION_KEY, SECRET_KEY, JWT_SECRET_KEY, WTF_CSRF_SECRET_KEY and VAPID
#     values from your current .env. A DIFFERENT ENCRYPTION_KEY makes all
#     encrypted PII permanently unrecoverable. scripts/migrate-to-single.sh
#     checks this for you.
#
# Generate a fresh secret:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Generate ENCRYPTION_KEY:  python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ---- App ----
APP_NAME=GearCargo
APP_PORT=5000
APP_URL=https://gearcargo.example.com
DEFAULT_THEME=dark

# ---- Core secrets (CHANGE ALL) ----
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me
WTF_CSRF_SECRET_KEY=change-me
ENCRYPTION_KEY=change-me-fernet-key

# ---- Embedded datastore passwords ----
# These secure the in-container PostgreSQL and Redis (loopback-only, but still
# password-protected). When migrating, set DB_PASSWORD to the SAME value you
# used before so the restored dump's role password matches.
DB_PASSWORD=change-me
REDIS_PASSWORD=change-me

# ---- Embedded server tuning (single container runs everything) ----
PG_SHARED_BUFFERS=256MB
PG_MAX_CONNECTIONS=100
REDIS_MAXMEMORY=128mb
GUNICORN_WORKERS=4

# ---- In-container scheduled backups ----
BACKUP_ENABLED=true
BACKUP_KEEP_LAST=7

# ---- Security ----
CORS_ORIGINS=https://gearcargo.example.com
RATELIMIT_DEFAULT=100 per hour
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000
# Number of trusted reverse proxies in front of the app (0=direct, 1=one proxy).
TRUSTED_PROXY_COUNT=1
# Optional domain-based access control
ADMIN_DOMAIN=
USER_DOMAIN=

# ---- Email (password reset / notifications) ----
MAIL_ENABLED=true
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=GearCargo <no-reply@example.com>

# ---- Push notifications ----
# VAPID_PRIVATE_KEY is provided via the Docker secret ./secrets/vapid_private_key
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ---- Uploads / GeoIP ----
MAX_UPLOAD_SIZE_MB=200
GEOIP_DB_PATH=

# ---- Ollama AI (optional) ----
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=
OLLAMA_MODEL=
OLLAMA_TIMEOUT=60
OLLAMA_MODEL_PREDICT=
OLLAMA_MODEL_OCR=
OLLAMA_MODEL_ANOMALY=
OLLAMA_MODEL_REMINDER=
